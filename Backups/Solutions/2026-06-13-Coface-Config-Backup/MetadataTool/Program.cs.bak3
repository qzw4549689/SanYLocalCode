                    { "mcs_filedate", "文件上传日期" },
                    { "mcs_api_status", "外部接口状态" }
                };
                break;

            case "mcs_customer_tag":
                fields = new Dictionary<string, string>
                {
                    { "mcs_credit_record", "信用评估" },
                    { "mcs_accountid", "客户编码" },
