    static void UpdateLookupView(EntityManager manager, string entityName)
    {
        var fields = new string[] { "mcs_credit_itemsno", "mcs_itemname", "mcs_group", "mcs_datatype" };
        manager.UpdateLookupView(entityName, fields);
    }

